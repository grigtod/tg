    "uuid": "ed7bb123-11c4-4f62-b13f-f5c167ba1dff",
    "audio_file": "challenges_ed7bb123-11c4-4f62-b13f-f5c167ba1dff.mp3"
  },
  "engine_fate": {
    "text": "Z czasem wydobycie osłabło, a maszynę wycofano z użycia.",
