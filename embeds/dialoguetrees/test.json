      {
        "text": "Czy wydobycie wzrosło?",
        "next": "production"
      },
      {
        "text": "Czy były też minusy?",
        "next": "downsides"
      },
      {
        "text": "Jak górnicy się dostosowali?",
        "next": "adapt"
