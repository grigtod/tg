      {
        "text": "Skąd brano węgiel?",
        "next": "coal"
      },
      {
        "text": "Czy zdarzały się wypadki?",
        "next": "accidents"
      },
      {
        "text": "Czy to zainspirowało nowe maszyny?",
        "next": "inspiration"
