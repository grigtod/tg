    "uuid": "6e1178be-c940-455b-af9a-245a8b9290f4",
    "audio_file": "hardships_6e1178be-c940-455b-af9a-245a8b9290f4.mp3"
  },
  "daily_tasks": {
    "text": "Mniej czasu poświęcano na odwadnianie, a więcej na skuteczne wydobywanie rudy.",
