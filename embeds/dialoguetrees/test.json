    "uuid": "a8b64084-e2c4-41f9-ad86-f42c43227036",
    "audio_file": "daily_tasks_a8b64084-e2c4-41f9-ad86-f42c43227036.mp3"
  },
  "challenges": {
    "text": "Maszyny wymagały paliwa, konserwacji i przeszkolonych operatorów.",
