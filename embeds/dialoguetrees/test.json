    "uuid": "b533c43a-25a2-4763-85d7-5cfa33cbcfdd",
    "audio_file": "engine_fate_b533c43a-25a2-4763-85d7-5cfa33cbcfdd.mp3"
  },
  "safety": {
    "text": "Stosowano proste obudowy i wentylację, ale ryzyko wciąż było wysokie.",
